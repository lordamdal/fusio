{
  "name": "fusio-protocol",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist services/*/dist apps/*/dist"
  },
  "engines": {
    "node": ">=22"
  }
}
